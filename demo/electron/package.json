{
  "name": "darknessdemo-electron",
  "version": "0.1.0",
  "description": "Electron desktop wrapper for the DarknessDemo reference app",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "se.soderbjorn.darknessdemo",
    "productName": "DarknessDemo",
    "copyright": "Copyright © 2026 Robert Söderbjörn",
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "resources/web/**/*",
      "resources/main/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
